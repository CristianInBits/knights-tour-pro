# Java & Gradle project .gitignore

# Build output

/build/
/out/
/bin/

# Gradle cache

.gradle/
!gradle/wrapper/gradle-wrapper.jar

# IDEs

.idea/
\*.iml
.vscode/

# Logs

\*.log

# Compiled class files

\*.class

# Package files

\*.jar
\*.war
\*.ear
\*.zip
\*.tar.gz
\*.rar

# JVM crash logs

hs\_err\_pid\*
replay\_pid\*

# BlueJ

\*.ctxt

# Mobile Tools for Java (J2ME)

.mtj.tmp/

# OS generated files

.DS\_Store
Thumbs.db
